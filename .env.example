# ── Database ──────────────────────────────────────────────────────────────────
# Neon (or any PostgreSQL) connection string
DB_URL=postgresql://user:password@host/dbname?sslmode=require

# ── LLM ───────────────────────────────────────────────────────────────────────
# LiteLLM model string — e.g. "openai/gpt-4o-mini", "anthropic/claude-3-5-haiku-20241022"
LLM_MODEL=openai/gpt-4o-mini

# API key for whichever provider LLM_MODEL uses
OPENAI_API_KEY=sk-...

# ── Internal auth ─────────────────────────────────────────────────────────────
# Shared secret between Cloudflare Worker and FastAPI; must match wrangler secret
INTERNAL_SECRET=change-me-in-production

# ── Schema ────────────────────────────────────────────────────────────────────
# Path to pre-built schema graph (relative to repo root); committed to git
SCHEMA_PATH=db/schema_index.json

# ── Debug server (local only) ─────────────────────────────────────────────────
# Set DEBUG=true to enable debug/server.py; NEVER set in production
DEBUG=false
DEBUG_PORT=9000
BACKEND_URL=http://localhost:8000

# ── Edge worker (Cloudflare) ──────────────────────────────────────────────────
# These are set via `wrangler secret put`, NOT stored here; documented for reference
# DASHBOARD_API_KEY=<bearer token the dashboard sends>
# DASHBOARD_ORIGIN=https://your-dashboard.vercel.app
# BACKEND_URL=https://your-api.vercel.app
